							"referenceName": "AzureSqlDatabase1",
							"type": "LinkedServiceReference"
						},
						"typeProperties": {
							"scripts": [
								{
									"type": "Query",
									"text": {
										"value": "select count(*) as count from @{pipeline().parameters.schema}.\n@{pipeline().parameters.table}\nwhere last_updated > \n'@{if(equals(pipeline().parameters.back_date,'1900-01-01'),activity('cdc_lookup').output.firstRow.cdc_timestamp,pipeline().parameters.back_date)}'",
										"type": "Expression"
									}
								}
							],
							"scriptBlockExecutionTimeout": "02:00:00"
						}
					},
					{
						"name": "ProceedOrNot",
						"type": "IfCondition",
						"dependsOn": [
							{
								"activity": "new_record_count",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"userProperties": [],
						"typeProperties": {
							"expression": {
								"value": "@greater(activity('new_record_count').output.resultSets[0].rows[0].count, 0)",
								"type": "Expression"
							},
							"ifTrueActivities": [
								{
									"name": "Incremental_data_load",
									"type": "Copy",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "AzureSqlSource",
											"sqlReaderQuery": {
												"value": "select * from @{pipeline().parameters.schema}.\n@{pipeline().parameters.table}\nwhere last_updated > '@{if(equals(pipeline().parameters.back_date,'1900-01-01'),activity('cdc_lookup').output.firstRow.cdc_timestamp,pipeline().parameters.back_date)}'",
												"type": "Expression"
											},
											"queryTimeout": "02:00:00",
											"partitionOption": "None"
										},
										"sink": {
											"type": "DelimitedTextSink",
